---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import About from "../components/About.astro";
import Experience from "../components/Experience.astro";
import Education from "../components/Education.astro";
import Projects from "../components/Projects.astro";
import Insights from "../components/Insights.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
import portfolioData from "../data/portfolio.json";

// todo: improve style
// todo: improve nav bar UI & UX

const title = "Vithushan";

const isVisible = (label: string) =>
	portfolioData.nav.links.find((link) => link.label === label)?.visible ??
	false;
---

<BaseLayout title={title}>
	<Hero />
	{isVisible("About") && <About />}
	{isVisible("Experience") && <Experience />}
	{isVisible("Education") && <Education />}
	{isVisible("Projects") && <Projects />}
	{isVisible("Insights") && <Insights />}
	{isVisible("Contact") && <Contact />}
	<Footer />
</BaseLayout>
