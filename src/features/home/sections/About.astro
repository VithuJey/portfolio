---
import { Image } from 'astro:assets';
import SectionHeading from '@/components/ui/SectionHeading.astro'
import { portfolio } from '@/lib/portfolio'

const { heading, paragraphs, skillHeading, skills, avatar } = portfolio.about
---

<section id='about'>
	<SectionHeading title={heading} />
	<div class='content-section'>
		<div class='left'>
			{
				paragraphs.map((paragraph, index) => (
					<>
						<p>{paragraph}</p>
						{index < paragraphs.length - 1 && <br />}
					</>
				))
			}
			<p class='skill-top'>
				{skillHeading}
			</p>
			<ul class='skill-list'>
				{skills.map((skill) => <li>{skill}</li>)}
			</ul>
		</div>
		<div class='right'>
			<div class='wrapper'>
				<Image src={avatar.src} alt={avatar.alt} width='300' height='300' />
			</div>
		</div>
	</div>
</section>

<style>
	.content-section {
		display: flex;
		align-items: center;
		width: 100%;
	}
	.left {
		width: 70%;
		margin-right: 10px;
	}
	.right {
		width: 30%;
	}
	.right .wrapper {
		display: flex;
		width: 320px;
		height: 320px;
		max-width: 100%;
		border-radius: 8px;
		box-shadow:
			var(--bg-color) 20px 20px 0px -3px,
			var(--tertiary-color) 20px 20px;
		transition: box-shadow 0.5s;
		overflow: hidden;
	}
	.right .wrapper:hover {
		box-shadow:
			var(--bg-color) 14px 14px 0px -3px,
			var(--secondary-color) 14px 14px;
	}
	.right img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 8px;
		filter: grayscale(100%) opacity(0.5) blur(0.5px);
		transition:
			transform 0.5s cubic-bezier(0.22, 1, 0.36, 1),
			filter 0.5s cubic-bezier(0.22, 1, 0.36, 1);
	}
	.right .wrapper:hover img {
		transform: scale(1.02);
		filter: blur(0.2px);
	}
	p {
		margin: auto;
	}
	.skill-top {
		margin-top: 20px;
	}
	.skill-list {
		display: grid;
		grid-template-columns: repeat(3, minmax(140px, 250px));
		list-style: none;
	}
	ul {
		list-style: none;
		padding: 0;
		margin: 10px 0 0 0;
	}
	.skill-list li {
		font-family: var(--font-mono);
		font-size: var(--font-md);
		line-height: var(--line-height-md);
		color: var(--tertiary-color);
		text-decoration: none;
		margin: 0 10px 10px 0;
	}
	.skill-list li::before {
		content: '▹ ';
		position: relative;
		color: var(--secondary-color);
	}
	.highlight-link {
		font-family: var(--font-mono);
		font-size: var(--font-md);
		line-height: var(--line-height-md);
		color: var(--secondary-color);
		background-color: var(--active-color);
		text-decoration: none;
		position: relative;
		display: inline-block;
	}
	.highlight-link:after {
		content: '';
		position: absolute;
		width: 100%;
		transform: scaleX(0);
		height: 1px;
		bottom: -1px;
		left: 0;
		background-color: var(--secondary-color);
		transform-origin: bottom right;
		transition: transform 0.25s ease-out;
	}
	.highlight-link:hover:after {
		transform: scaleX(1);
		transform-origin: bottom left;
	}
	@media only screen and (max-width: 375px) {
		.skill-list {
			display: grid;
			grid-template-columns: repeat(3, minmax(130px, 130px));
			list-style: none;
		}
	}
	@media only screen and (max-width: 320px) {
		.skill-list {
			display: grid;
			grid-template-columns: repeat(3, minmax(100px, 100px));
			list-style: none;
		}
	}
	@media only screen and (max-width: 768px) {
		.content-section {
			display: flex;
			flex-direction: column;
			align-items: center;
			width: 100%;
		}

		.left {
			width: 100%;
			margin-right: 0;
			margin-bottom: 20px;
		}
		.right {
			width: 50%;
		}
	}
	@media only screen and (min-width: 1920px) {
		.content-section {
			align-items: flex-start;
		}
	}
</style>
