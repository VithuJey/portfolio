---
import portfolioData from "../data/portfolio.json";
const { heading, list } = portfolioData.insights;

const typeIcons: Record<string, { svg: string; label: string }> = {
	article: {
		svg: '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>',
		label: "Article",
	},
	video: {
		svg: '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>',
		label: "Video",
	},
};

const getYoutubeThumbnail = (url: string) => {
	const match = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([^&\n?#]+)/);

	return match ? `https://img.youtube.com/vi/${match[1]}/hqdefault.jpg` : url;
};
---

<section id="insights">
	<h3 class="content-heading">{heading}</h3>

	<div class="insights-grid">
		{list.map((item) => {
			const icon = typeIcons[item.type] || typeIcons.article;
			return (
				<a
					class="insight-tile"
					href={item.link}
					target="_blank"
					rel="noopener noreferrer"
				>
					<div class="tile-thumbnail">
						<img
							src={getYoutubeThumbnail(item.thumbnail)}
							alt={item.title}
							loading="lazy"
						/>
						<span class="type-badge" title={icon.label}>
							<Fragment set:html={icon.svg} />
						</span>
					</div>
					<div class="tile-content">
						<p class="tile-title">{item.title}</p>
						<p class="tile-desc">{item.desc}</p>
					</div>
				</a>
			);
		})}
	</div>
</section>

<style>
	.insights-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 24px;
		margin-top: 40px;
	}

	.insight-tile {
		background-color: var(--card-color);
		border-radius: 10px;
		overflow: hidden;
		text-decoration: none;
		box-shadow: rgb(2 12 27 / 70%) 0px 10px 30px -10px;
		transition: transform 0.25s ease, box-shadow 0.25s ease;
	}

	.insight-tile:hover {
		transform: translateY(-5px);
		box-shadow: rgb(2 12 27 / 90%) 0px 20px 30px -10px;
	}

	.tile-thumbnail {
		width: 100%;
		height: 180px;
		overflow: hidden;
		position: relative;
	}

	.tile-thumbnail img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.3s ease;
	}

	.insight-tile:hover .tile-thumbnail img {
		transform: scale(1.05);
	}

	.type-badge {
		position: absolute;
		top: 10px;
		left: 10px;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 32px;
		height: 32px;
		border-radius: 8px;
		backdrop-filter: blur(4px);
		-webkit-backdrop-filter: blur(4px);
		color: var(--secondary-color);
	}

	.tile-content {
		padding: 20px;
	}

	.tile-title {
		font-family: var(--font-sans);
		font-size: var(--font-lg);
		font-weight: 600;
		line-height: var(--line-height-lg);
		color: var(--primary-color);
		margin: 0 0 8px 0;
	}

	.tile-desc {
		font-family: var(--font-sans);
		font-size: var(--font-sm);
		line-height: var(--line-height-sm);
		color: var(--tertiary-color);
		margin: 0;
	}

	@media only screen and (max-width: 768px) {
		.insights-grid {
			grid-template-columns: 1fr;
			gap: 20px;
		}
	}

	@media only screen and (min-width: 769px) and (max-width: 1024px) {
		.insights-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}
</style>
