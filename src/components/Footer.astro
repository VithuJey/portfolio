---
import portfolioData from "../data/portfolio.json";
const { socials, footer } = portfolioData;
---

<div class="footer">
	<div class="social-list">
		{
			socials.filter(social => social.visible).map(social => (
				<a
					href={social.url}
					target="_blank"
					rel="noopener noreferrer"
				>
					<img
						class="social-icons"
						src={social.icon}
						alt={social.alt}
						height="22px"
					/>
				</a>
			))
		}
	</div>
	<p>{footer.builtWithText}</p>
	<a href={footer.builtWithUrl} target="_blank" rel="noopener noreferrer"
		><img src={footer.builtWithLogo} alt={footer.builtWithAlt} height="40px" />
	</a>
</div>

<style>
	.footer {
		margin-bottom: 20px;
		display: flex;
		flex-direction: column;
		align-items: center;
	}
	.footer > * {
		margin-bottom: 20px;
	}
	.social-list {
		display: none;
	}
	p,
	a {
		font-family: var(--font-mono);
		font-size: var(--font-sm);
		color: var(--tertiary-color);
		text-align: center;
		text-decoration: none;
	}
	a:hover {
		color: var(--secondary-color);
	}
	@media only screen and (max-width: 768px) {
		.social-list {
			display: block;
			text-align: center;
		}
		.social-list a {
			margin: 0 18px;
		}
		.social-icons {
			filter: brightness(0) invert(1) opacity(0.7);
		}
	}
</style>
