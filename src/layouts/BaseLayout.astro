---
import Name from "../components/Name.astro";
import Nav from "../components/Nav.astro";
import SocialList from "../components/SocialList.astro";
import "../styles/global.css";
interface Props {
	title: string;
}

const { title } = Astro.props as Props;
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta
			name="viewport"
			content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"
		/>
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />

		<!-- SEO Meta Tags -->
		<meta name="description" content="Vithushan Jeyasothy - Senior Software Engineer. Building premium, human-centric digital experiences with React, Next.js, and React Native." />
		<meta name="keywords" content="Vithushan, Vithushan Jeyasothy, Software Engineer, Frontend Engineer, React Developer, React Native, Next.js, Colombo, Amsterdam, London" />
		<meta name="author" content="Vithushan Jeyasothy" />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title || "Vithushan | Senior Software Engineer"} />
		<meta property="og:description" content="Vithushan is a software engineer specializing in building premium, human-centric digital experiences." />
		<meta property="og:site_name" content="Vithushan Portfolio" />
		<meta property="og:image" content="/images/vithu.jpg" />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title || "Vithushan | Senior Software Engineer"} />
		<meta name="twitter:description" content="Vithushan is a software engineer specializing in building premium, human-centric digital experiences." />
		<meta name="twitter:image" content="/images/vithu.jpg" />

		<!-- google fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<!-- font: Inter -->
		<!-- <link
			href="https://fonts.googleapis.com/css2?family=Inter&display=swap"
			rel="stylesheet"
		/> -->
		<!-- font: Space Mono -->
		<link
			href="https://fonts.googleapis.com/css2?family=Space+Mono&display=swap"
			rel="stylesheet"
		/>
		<!-- font: syne -->
		<link 
			href="https://fonts.googleapis.com/css2?family=Syne&display=swap" 
			rel="stylesheet"
		>

		<!-- Page Title -->
		<title>{title}</title>
	</head>
	<body>
		<Nav />
		<main id="content">
			<slot />
		</main>
		<SocialList />
		<Name />
		<style>
			#content {
				margin: auto;
				padding: 0 25px;
				max-width: 1600px;
				min-height: 100vh;
			}
			@media only screen and (min-width: 768px) {
				#content {
					padding: 0 50px;
				}
			}
			@media only screen and (min-width: 992px) {
				#content {
					padding: 0 130px;
				}
			}
			@media only screen and (min-width: 1440px) {
				#content {
					padding: 0 250px;
				}
			}
			@media only screen and (min-width: 1920px) {
				#content {
					padding: 0 450px;
				}
			}
			@media only screen and (min-width: 2560px) {
				#content {
					padding: 0 650px;
					max-width: 1200px;
				}
			}
		</style>
	</body>
</html>
